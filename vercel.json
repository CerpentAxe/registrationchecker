{
  "version": 2,
  "builds": [
    {
      "src": "src/server.js",
      "use": "@vercel/node"
    }
  ],
  "functions": {
    "src/server.js": {
      "includeFiles": "node_modules/pdfjs-dist/legacy/build/**"
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "src/server.js"
    }
  ]
}
